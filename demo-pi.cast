[106.32233, "o", "\u001b[?2026h\u001b[4A\r\u001b[2K\u001b]133;A\u0007\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b]133;B\u0007\u001b]133;C\u0007 \u001b[3m\u001b[38;2;128;128;128mThe\u001b[39m\u001b[23m                                                                                                \u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K \u001b[38;2;138;190;183m‚Ý¶\u001b[39m \u001b[38;2;128;128;128mWorking...\u001b[39m                                                                                       \u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[2K\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u001b[38;2;178;148;187m‚îÄ\u001b[39m\u0