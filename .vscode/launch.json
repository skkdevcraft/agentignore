
{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable",
            "cargo": {
                "args": [
                    "build",
                    "--bin=agentignore",
                    "--package=agentignore",
                    "--manifest-path=Cargo.toml"
                ],
                "filter": {
                    "kind": "bin"
                }
            },
            "args": []
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable",
            "cargo": {
                "args": [
                    "test"
                ]
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}